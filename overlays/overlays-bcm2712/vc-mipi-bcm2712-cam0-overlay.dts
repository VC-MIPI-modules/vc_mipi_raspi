//




/dts-v1/;
/plugin/;

/ {
    fragment@0 {
     
		target = <&csi0>;
		__overlay__ {
			status = "okay";

			port {
				csi2_ep: endpoint {
					remote-endpoint = <&vc_mipi_cam0_ep>;
					data-lanes = <1 2 3 4>;

				};
			};
		};
	};
	fragment@1 {
		target = <&i2c_csi_dsi0>;
		status = "okay";
		__overlay__ {
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";
			brcm,media-controller;

			vc_mipi_cam0: camera1{				
				compatible = "vc,vc_mipi_camera";
				reg = <0x1a>;
				status = "okay";				
				port {
					vc_mipi_cam0_ep: endpoint {
						remote-endpoint = <&csi2_ep>;
						data-lanes = <1 2 3 4>;

					};
				};
			};
		};
	};
	fragment@2 {
		target = <&i2c0mux>;
		__overlay__ {
			status = "okay";

		};
	};
	fragment@3 {
		target = <&i2c0if>;
		__overlay__ {
			status = "okay";

		};
	};
	fragment@4 {
    	target-path = "/cam0_reg";
    	__overlay__ {
       		status = "disabled";
    	};
	};
	fragment@5 {
		target = <&rp1_gpio>;
		__overlay__ {
			cam0_trigger_gpio: cam0_trigger_gpio {
				function = "gpio";
				pins = "gpio40";
				drive-strength = <0x0c>;   /* optional */
				bias-disable;              /* no pull */
				/* slew-rate = <0x01>; */  /* optional */
			};
		};
    };
	fragment@1001 {
		target = <&i2c_csi_dsi0>;
		__dormant__ {
			camera1 {
				port {
						endpoint {
							data-lanes = <1>;

						};
					};
				};
		};
	};
	fragment@1002 {
		target = <&i2c_csi_dsi0>;
		__dormant__ {
			camera1 {
				port {
						endpoint {
							data-lanes = <1 2>;

						};
					};
				};
		};
	};
	fragment@1004 {
		target = <&i2c_csi_dsi0>;
		__dormant__ {
			camera1 {
				port {
						endpoint {
							data-lanes = <1 2 3 4>;

						};
					};
				};
		};
	};
	fragment@2001 {
		target = <&csi0>;
		__dormant__ {
			status = "okay";
            brcm,num-data-lanes = <0x01>;
			port {
				endpoint {
					data-lanes = <1>;

				};
			};
		};
	};
	fragment@2002 {
		target = <&csi0>;
		__dormant__ {
			status = "okay";
            brcm,num-data-lanes = <0x02>;

			port {
				endpoint {
					data-lanes = <1 2>;

				};
			};
		};
	};
	fragment@2004 {
		target = <&csi0>;
		__dormant__ {
			status = "okay";
            brcm,num-data-lanes = <0x04>;
			port {
				endpoint {
					data-lanes = <1 2 3 4>;

				};
			};
		};
	};

	__overrides__ {
        cam0_lanes1 	   	=      <0>,"=1001=2001";
		cam0_lanes2 	   	=      <0>,"=1002=2002";
		cam0_lanes4 	   	=      <0>,"=1004=2004";		
		cam0_lanes0 	   	= 	   <0>,"-0-1";
		cam0_manu_ov	   	=      <&vc_mipi_cam0>,"reg:0=",<0x60>;
		cam0_libcamera_on	=      <&vc_mipi_cam0>,"libcamera";
		cam0_force_color	=      <&vc_mipi_cam0>,"force-color-mode";


    };
};